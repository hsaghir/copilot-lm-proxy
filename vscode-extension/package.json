{
    "name": "copilot-lm-proxy",
    "displayName": "Copilot LM Proxy",
    "description": "Exposes Copilot LLM via local HTTP server for external scripts",
    "version": "0.2.0",
    "publisher": "hsaghir",
    "repository": {
        "type": "git",
        "url": "https://github.com/hsaghir/copilot-lm-proxy"
    },
    "license": "MIT",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "copilot-lm-proxy.start",
                "title": "Copilot LM Proxy: Start Server"
            },
            {
                "command": "copilot-lm-proxy.stop",
                "title": "Copilot LM Proxy: Stop Server"
            }
        ],
        "configuration": {
            "title": "Copilot LM Proxy",
            "properties": {
                "copilot-lm-proxy.port": {
                    "type": "number",
                    "default": 19823,
                    "description": "Port for the proxy HTTP server"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.90.0",
        "typescript": "^5.0.0"
    }
}